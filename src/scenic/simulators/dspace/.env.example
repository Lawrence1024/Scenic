# dSPACE CMU license server URL (rotates over time; obtain from the dSPACE CMU
# group). Used by `dspace_art_cosim_stack.yml` and any sibling compose files
# that need DS_CMU_SERVER.
DS_CMU_SERVER=

# Absolute paths used by the docker compose stacks. Substituted at compose
# launch via ${VAR} expansion in the .yml files. Set these to match your
# local install. The defaults work for the original development environment
# but will not match other developers' machines.
#
# SCENIC_ROOT      - repo root, in WSL form, e.g. /mnt/c/Users/<you>/Documents/Scenic/Scenic
# DSPACE_INSTALL   - dSPACE SimulationPackage install root, e.g. /mnt/c/Users/<you>/Documents/dspace
# RACE_COMMON_ROOT - your race_common ROS workspace clone, e.g. /home/<you>/ros_ws/race_common
# HOST_SSH_KEY     - absolute path to the SSH key used inside containers, e.g. /home/<you>/.ssh/id_ed25519
SCENIC_ROOT=/mnt/c/Users/<your-username>/Documents/Scenic/Scenic
DSPACE_INSTALL=/mnt/c/Users/<your-username>/Documents/dspace
RACE_COMMON_ROOT=/home/<your-username>/ros_ws/race_common
HOST_SSH_KEY=/home/<your-username>/.ssh/id_ed25519

# Copy this file to `.env` in the same directory and fill in the actual values.
# The .env file is gitignored at the repo root.
