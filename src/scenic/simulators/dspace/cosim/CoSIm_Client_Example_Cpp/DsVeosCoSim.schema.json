{
    "$schema": "https://json-schema.org/draft/2019-09/schema",
    "type": "object",
    "allOf": [
        {
            "$ref": "simulator-extension.base.schema.json"
        }
    ],
    "properties": {
        "Type": {
            "const": "DsVeosCoSim"
        },
        "TcpPort": {
